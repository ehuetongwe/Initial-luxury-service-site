# API Keys and Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.

# --- Supabase ---
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY  # server-side only, never expose client-side

# --- EmailJS ---
EMAILJS_PUBLIC_KEY=YOUR_EMAILJS_PUBLIC_KEY
EMAILJS_SERVICE_ID=YOUR_EMAILJS_SERVICE_ID
EMAILJS_TEMPLATE_ID=YOUR_EMAILJS_TEMPLATE_ID

# --- n8n Automation ---
# Webhook URL for reservation_request automation trigger.
# Set this in website/js/config.js under N8N_WEBHOOK_URL for the static site.
N8N_WEBHOOK_URL=https://ehuetongwe.app.n8n.cloud/webhook/luxury-reservation
